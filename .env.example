OLLAMA_HOST=http://localhost:11434
KLINIKA_DB_PATH=./data/klinika.db
KLINIKA_CHAT_MODEL=gemma4:e2b
# KLINIKA_CHAT_MODEL=gemma4:e4b
# KLINIKA_CHAT_MODEL=gemma4:26b
KLINIKA_EMBED_MODEL=nomic-embed-text

# Voice transcription
# KLINIKA_WHISPER_MODEL=base  # tiny / base / small / medium

# Bridge: GDT bidirectional (PVS device integration)
# Set to the folder you configure in your PVS device settings (TURBOMED, medatixx, etc.)
# Leave empty to disable.
# KLINIKA_GDT_FOLDER=./data/gdt_inbox
# KLINIKA_GDT_DEVICE_ID=KLINIKA   # 8-char identifier entered in PVS device settings

# Bridge: LDT lab folder watch (labGate drop folder)
# Set to the folder where labGate writes .ldt files (same folder your PVS watches).
# Leave empty to disable.
# KLINIKA_LDT_FOLDER=./data/lab_inbox

# MCP plugin servers (Mode 2 — vendor-built specialist AI plugins)
# Comma-separated paths to MCP server scripts. Each runs as a subprocess.
# Example: a cardiac AI vendor ships plugins/ecg_server.py with their device.
# KLINIKA_MCP_SERVERS=plugins/ecg_server.py
